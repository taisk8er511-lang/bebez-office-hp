{
  "version": 2,
  "buildCommand": "cd backend && npm install",
  "outputDirectory": "./",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/backend/server.js"
    }
  ],
  "functions": {
    "backend/server.js": {
      "runtime": "nodejs18.x"
    }
  }
}
